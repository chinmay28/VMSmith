# vmSmith configuration
# Copy to ~/.vmsmith/config.yaml or /etc/vmsmith/config.yaml

daemon:
  listen: "0.0.0.0:8080"
  pid_file: "/var/run/vmsmith.pid"
  log_file: "~/.vmsmith/vmsmith.log"   # structured log output; leave empty to disable file logging

libvirt:
  uri: "qemu:///system"       # Use qemu:///session for rootless operation

storage:
  images_dir: "/var/lib/vmsmith/images"   # world-accessible; libvirt-qemu can read here
  base_dir: "/var/lib/vmsmith/vms"        # world-accessible; libvirt-qemu can read here
  db_path: "~/.vmsmith/vmsmith.db"        # user-only metadata DB

network:
  name: "vmsmith-net"
  subnet: "192.168.100.0/24"
  dhcp_start: "192.168.100.10"
  dhcp_end: "192.168.100.254"

defaults:
  cpus: 2
  ram_mb: 2048
  disk_gb: 20
  ssh_user: ubuntu   # retained for config compatibility; VMs use root by default — set default_user per-VM via CLI/API/GUI to create a named sudo user instead
